<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.ProductManagementController"
      alignment="CENTER"
      spacing="12">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Product Management" styleClass="title-label"/>
    <TextField fx:id="productNameField" promptText="Product name" maxWidth="300"/>
    <TextField fx:id="priceField" promptText="Start price" maxWidth="300"/>
    <Button text="Add Product" onAction="#onAddProduct" prefWidth="220"/>
    <Button text="Back Home" onAction="#onBackHome" prefWidth="220"/>
    <Label fx:id="messageLabel"/>
</VBox>