<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.MyAuctionsController"
            styleClass="root"
            prefWidth="1280"
            prefHeight="800">

    <left>
        <StackPane fx:id="sidebarContainer"/>
    </left>

    <center>
        <VBox spacing="32">
            <padding>
                <Insets top="48" right="48" bottom="0" left="48"/>
            </padding>

            <VBox spacing="10">
                <Label text="Phiên đấu giá của tôi" styleClass="title-serif"/>
                <Label text="Tất cả phiên đấu giá bạn đã tham gia." styleClass="text-secondary"/>
                <Region styleClass="champagne-divider"/>
            </VBox>

            <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                <tabs>
                    <Tab>
                        <text>Đang tham gia</text>
                        <content>
                            <ScrollPane fitToWidth="true"
                                        style="-fx-background: transparent; -fx-background-color: transparent;">
                                <VBox spacing="16">
                                    <padding>
                                        <Insets top="20" right="20" bottom="20" left="0"/>
                                    </padding>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label fx:id="countParticipating" text="0" styleClass="title-serif-medium"/>
                                        <Label text="phiên" styleClass="text-secondary"/>
                                    </HBox>
                                    <FlowPane fx:id="participatingGrid" hgap="20" vgap="20"/>
                                </VBox>
                            </ScrollPane>
                        </content>
                    </Tab>
                    <Tab>
                        <text>Đã thắng</text>
                        <content>
                            <ScrollPane fitToWidth="true"
                                        style="-fx-background: transparent; -fx-background-color: transparent;">
                                <VBox spacing="16">
                                    <padding>
                                        <Insets top="20" right="20" bottom="20" left="0"/>
                                    </padding>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label fx:id="countWon" text="0" styleClass="title-serif-medium"/>
                                        <Label text="phiên" styleClass="text-secondary"/>
                                    </HBox>
                                    <FlowPane fx:id="wonGrid" hgap="20" vgap="20"/>
                                </VBox>
                            </ScrollPane>
                        </content>
                    </Tab>
                    <Tab>
                        <text>Đã thua</text>
                        <content>
                            <ScrollPane fitToWidth="true"
                                        style="-fx-background: transparent; -fx-background-color: transparent;">
                                <VBox spacing="16">
                                    <padding>
                                        <Insets top="20" right="20" bottom="20" left="0"/>
                                    </padding>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label fx:id="countLost" text="0" styleClass="title-serif-medium"/>
                                        <Label text="phiên" styleClass="text-secondary"/>
                                    </HBox>
                                    <FlowPane fx:id="lostGrid" hgap="20" vgap="20"/>
                                </VBox>
                            </ScrollPane>
                        </content>
                    </Tab>
                </tabs>
            </TabPane>
        </VBox>
    </center>

</BorderPane>