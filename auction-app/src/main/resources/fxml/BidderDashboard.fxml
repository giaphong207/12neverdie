<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.BidderDashboardController"
            styleClass="root"
            prefWidth="1280"
            prefHeight="800">

    <!-- === TOPBAR BÊN TRÊN === -->
    <top>
        <StackPane fx:id="topbarContainer"/>
    </top>

    <!-- === CONTENT AREA Ở GIỮA === -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox spacing="32">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>

                <!-- Welcome heading -->
                <Label fx:id="welcomeLabel" 
                       text="Chào mừng trở lại..." 
                       styleClass="title-large"/>

                <!-- Stat cards (3 ô) -->
                <HBox fx:id="statCardsContainer" spacing="20"/>

                <!-- Section: Phiên đấu giá nổi bật -->
                <VBox spacing="16">
                    <Label text="Phiên đấu giá nổi bật" 
                           styleClass="title-medium"/>
                    <FlowPane fx:id="featuredAuctionsContainer" 
                              hgap="20" 
                              vgap="20"/>
                </VBox>

                <!-- Section: Phiên kết thúc trong giờ tới -->
                <VBox spacing="16">
                    <Label text="Phiên kết thúc trong giờ tới" 
                           styleClass="title-medium"/>
                    <VBox fx:id="endingSoonContainer" spacing="12"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>