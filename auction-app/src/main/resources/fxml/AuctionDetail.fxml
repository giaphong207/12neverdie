<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.AuctionDetailController"
            styleClass="root"
            prefWidth="1280"
            prefHeight="800">

    <!-- === SIDEBAR === -->
    <left>
        <StackPane fx:id="sidebarContainer"/>
    </left>

    <!-- === CONTENT AREA === -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox spacing="20">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>

                <!-- === BREADCRUMB + BACK BUTTON === -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button text="← Quay lại" 
                            styleClass="btn-text" 
                            onAction="#onBackClicked"/>
                    <Label text="PHIÊN ĐẤU GIÁ › ĐANG DIỄN RA" 
                           styleClass="label-caption"/>
                </HBox>

                <!-- === TIÊU ĐỀ === -->
                <Label fx:id="itemNameLabel" 
                       text="Đang tải..." 
                       styleClass="title-large"/>

                <!-- === LAYOUT 2 CỘT === -->
                <HBox spacing="32" VBox.vgrow="ALWAYS">

                    <!-- === CỘT TRÁI: Mô tả + Tabs === -->
                    <VBox spacing="20" HBox.hgrow="ALWAYS">

                        <!-- Card mô tả -->
                        <VBox styleClass="card" spacing="12">
                            <Label text="MÔ TẢ" styleClass="label-caption"/>
                            <Label fx:id="descriptionLabel"
                                   text="Đang tải..."
                                   wrapText="true"
                                   styleClass="text-secondary"/>
                            <Separator/>
                            <HBox spacing="24">
                                <VBox spacing="4">
                                    <Label text="NGƯỜI BÁN" styleClass="label-caption"/>
                                    <Label fx:id="sellerLabel" 
                                           text="—" 
                                           styleClass="text-body"/>
                                </VBox>
                                <VBox spacing="4">
                                    <Label text="TRẠNG THÁI" styleClass="label-caption"/>
                                    <Label fx:id="statusLabel" 
                                           text="—" 
                                           styleClass="badge-running"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Tabs: Lịch sử + Biểu đồ -->
                        <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                            <Tab text="LỊCH SỬ ĐẤU GIÁ">
                                <ListView fx:id="bidHistoryListView"/>
                            </Tab>
                            <Tab text="BIỂU ĐỒ GIÁ">
                                <LineChart fx:id="bidHistoryChart"
                                           createSymbols="true"
                                           legendVisible="false"
                                           animated="false">
                                    <xAxis>
                                        <CategoryAxis fx:id="bidTimeAxis" label="Thời gian"/>
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis fx:id="bidPriceAxis" label="Giá (VND)"/>
                                    </yAxis>
                                </LineChart>
                            </Tab>
                        </TabPane>
                    </VBox>

                    <!-- === CỘT PHẢI: Countdown + Đặt giá === -->
                    <VBox spacing="16" prefWidth="380" minWidth="340" maxWidth="420">

                        <!-- Card countdown + giá -->
                        <VBox styleClass="card" spacing="14">
                            <Label text="KẾT THÚC SAU" styleClass="label-caption"/>
                            <Label fx:id="remainingTimeLabel"
                                   text="--:--:--"
                                   styleClass="countdown-text"/>

                            <Separator/>

                            <Label text="GIÁ HIỆN TẠI" styleClass="label-caption"/>
                            <Label fx:id="currentPriceLabel"
                                   text="—"
                                   styleClass="price-big"/>

                            <Label fx:id="highestBidderLabel"
                                   text="Người dẫn đầu: —"
                                   styleClass="text-muted"/>
                        </VBox>

                        <!-- Card đặt giá -->
                        <VBox styleClass="card" spacing="14">
                            <Label text="GIÁ BẠN MUỐN ĐẶT (VND)" 
                                   styleClass="label-caption"/>
                            <TextField fx:id="bidAmountField" 
                                       promptText="Nhập số tiền..."/>

                            <Label fx:id="messageLabel"
                                   text=""
                                   styleClass="text-muted"
                                   wrapText="true"/>

                            <Button fx:id="placeBidButton"
                                    text="Đặt giá"
                                    styleClass="btn-primary"
                                    onAction="#onPlaceBidClicked"
                                    maxWidth="Infinity"/>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>