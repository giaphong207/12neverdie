<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.AuctionDetailController"
      alignment="CENTER_LEFT"
      spacing="12">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="Auction Detail"
           styleClass="title-label"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <Label text="Tên sản phẩm:"/>
    <Label fx:id="itemNameLabel"/>

    <Label text="Mô tả:"/>
    <Label fx:id="descriptionLabel" wrapText="true"/>

    <Label text="Seller:"/>
    <Label fx:id="sellerLabel"/>

    <Label text="Giá hiện tại:"/>
    <Label fx:id="currentPriceLabel"
           style="-fx-font-weight: bold; -fx-font-size: 16px;"/>

    <Label text="Trạng thái:"/>
    <Label fx:id="statusLabel"/>

    <Label text="Thời gian còn lại:"/>
    <Label fx:id="remainingTimeLabel"/>

    <Label fx:id="highestBidderLabel"
           text="Người dẫn đầu: Chưa có"
           style="-fx-font-weight: bold; -fx-text-fill: #d35400;"/>

    <Label text="Lịch sử đấu giá:"/>
    <ListView fx:id="bidHistoryListView"
              prefHeight="120"
              prefWidth="300"/>

    <Label text="Biểu đồ lịch sử giá:"
           style="-fx-font-weight: bold; -fx-font-size: 15px;"/>

    <LineChart fx:id="bidHistoryChart"
               title="Bid History"
               animated="false"
               createSymbols="true"
               legendVisible="false"
               prefHeight="260"
               prefWidth="520">
        <xAxis>
            <CategoryAxis fx:id="bidTimeAxis" label="Thời điểm bid"/>
        </xAxis>
        <yAxis>
            <NumberAxis fx:id="bidPriceAxis" label="Giá bid"/>
        </yAxis>
    </LineChart>

    <Label text="Nhập giá đặt (VND):"/>
    <TextField fx:id="bidAmountField"
               promptText="Ví dụ: 21000000"
               prefWidth="220"/>

    <Button fx:id="placeBidButton"
            text="Place Bid"
            onAction="#onPlaceBidClicked"
            prefWidth="220"
            style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Button text="Back"
            onAction="#onBackClicked"
            prefWidth="220"/>

    <Label fx:id="messageLabel" wrapText="true"/>

</VBox>