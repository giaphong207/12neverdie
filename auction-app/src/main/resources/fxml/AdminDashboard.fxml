<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.AdminDashboardController"
            styleClass="root"
            prefWidth="1280"
            prefHeight="800">

    <!-- === TOPBAR === -->
    <top>
        <StackPane fx:id="topbarContainer"/>
    </top>

    <!-- === CONTENT AREA === -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox spacing="32">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>

                <!-- === HEADER === -->
                <VBox spacing="8">
                    <Label text="Tổng quan hệ thống" styleClass="title-large"/>
                    <Label text="Số liệu hệ thống và hoạt động người dùng trong kỳ hiện tại"
                           styleClass="text-secondary"/>
                </VBox>

                <!-- === STAT CARDS === -->
                <HBox fx:id="statCardsContainer" spacing="20"/>

                <!-- === RECENT USERS TABLE === -->
                <VBox spacing="16">
                    <Label text="Hoạt động người dùng gần đây" 
                           styleClass="title-medium"/>
                    <TableView fx:id="usersTable" prefHeight="320">
                        <columns>
                            <TableColumn fx:id="colUserName" 
                                         text="Người dùng" 
                                         prefWidth="220"/>
                            <TableColumn fx:id="colUserRole" 
                                         text="Vai trò" 
                                         prefWidth="180"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>