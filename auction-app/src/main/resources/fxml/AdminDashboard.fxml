<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.AdminDashboardController"
            styleClass="root"
            prefWidth="1280"
            prefHeight="800">

    <left>
        <StackPane fx:id="sidebarContainer"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="32">
                <padding>
                    <Insets top="48" right="48" bottom="48" left="48"/>
                </padding>

                <VBox spacing="10">
                    <Label text="Tổng quan hệ thống" styleClass="title-serif"/>
                    <Label text="Số liệu hệ thống và hoạt động người dùng trong kỳ hiện tại"
                           styleClass="text-secondary"/>
                    <Region styleClass="champagne-divider"/>
                </VBox>

                <HBox fx:id="statCardsContainer" spacing="20"/>

                <VBox spacing="16">
                    <Label text="Hoạt động người dùng gần đây" styleClass="title-serif-medium"/>
                    <TableView fx:id="usersTable" prefHeight="320">
                        <columns>
                            <TableColumn fx:id="colUserName" text="Người dùng" prefWidth="220"/>
                            <TableColumn fx:id="colUserRole" text="Vai trò" prefWidth="180"/>
                            <TableColumn fx:id="colUserActivity" text="Hoạt động gần nhất" prefWidth="200"/>
                            <TableColumn fx:id="colUserStatus" text="Trạng thái" prefWidth="160"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>