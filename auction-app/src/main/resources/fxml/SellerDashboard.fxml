<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.SellerDashboardController"
            styleClass="root"
            prefWidth="1280"
            prefHeight="800">

    <!-- === SIDEBAR === -->
    <left>
        <StackPane fx:id="sidebarContainer"/>
    </left>

    <!-- === CONTENT AREA === -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox spacing="32">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>

                <!-- === HEADER === -->
                <Label text="Tổng quan" styleClass="title-large"/>

                <!-- === STAT CARDS === -->
                <HBox fx:id="statCardsContainer" spacing="20"/>

                <!-- === RECENT AUCTIONS TABLE === -->
                <VBox spacing="16">
                    <Label text="Phiên đấu giá gần đây" 
                           styleClass="title-medium"/>
                    <TableView fx:id="recentAuctionsTable" prefHeight="320">
                        <columns>
                            <TableColumn fx:id="colLot" 
                                         text="Mã LOT" 
                                         prefWidth="160"/>
                            <TableColumn fx:id="colCurrentPrice" 
                                         text="Giá hiện tại" 
                                         prefWidth="220"/>
                            <TableColumn fx:id="colStatus" 
                                         text="Trạng thái" 
                                         prefWidth="180"/>
                            <TableColumn fx:id="colEndTime" 
                                         text="Kết thúc" 
                                         prefWidth="160"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>