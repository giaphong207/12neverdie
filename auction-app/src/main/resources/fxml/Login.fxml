<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.auction.client.controller.LoginController" prefHeight="400.0" prefWidth="600.0">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="HỆ THỐNG ĐẤU GIÁ TRỰC TUYẾN" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    
    <TextField fx:id="txtUsername" promptText="Tên đăng nhập" maxWidth="250"/>
    <PasswordField fx:id="txtPassword" promptText="Mật khẩu" maxWidth="250"/>
    
    <Button text="Đăng Nhập" onAction="#onLoginClicked" prefWidth="250"/>
    <Button text="Chưa có tài khoản? Đăng ký ngay" onAction="#onOpenRegisterClicked" prefWidth="250"/>
</VBox> 