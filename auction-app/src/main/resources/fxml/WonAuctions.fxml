<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.WonAuctionsController"
            styleClass="root"
            prefWidth="1280"
            prefHeight="800">

    <left>
        <StackPane fx:id="sidebarContainer"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="32">
                <padding>
                    <Insets top="48" right="48" bottom="48" left="48"/>
                </padding>

                <VBox spacing="10">
                    <Label text="Phiên đấu giá đã thắng" styleClass="title-serif"/>
                    <Label fx:id="summaryLabel"
                           text="Đang tải..."
                           styleClass="text-secondary"/>
                    <Region styleClass="champagne-divider"/>
                </VBox>

                <TableView fx:id="wonTable" prefHeight="500">
                    <columns>
                        <TableColumn fx:id="colLot" text="Mã LOT" prefWidth="200"/>
                        <TableColumn fx:id="colPrice" text="Giá thắng" prefWidth="260"/>
                        <TableColumn fx:id="colWonAt" text="Thắng lúc" prefWidth="200"/>
                        <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="180"/>
                    </columns>
                </TableView>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>