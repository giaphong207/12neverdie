<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.SellerAuctionsController"
            styleClass="root"
            prefWidth="1280"
            prefHeight="800">

    <!-- === SIDEBAR === -->
    <left>
        <StackPane fx:id="sidebarContainer"/>
    </left>

    <!-- === CONTENT AREA === -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox spacing="32">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>

                <!-- === HEADER === -->
                <VBox spacing="8">
                    <Label text="Phiên đấu giá của tôi" 
                           styleClass="title-large"/>
                    <Label fx:id="summaryLabel" 
                           text="Đang tải..." 
                           styleClass="text-secondary"/>
                </VBox>

                <!-- === STAT CARDS === -->
                <HBox fx:id="statCardsContainer" spacing="20"/>

                <!-- === ALL AUCTIONS GRID === -->
                <VBox spacing="16">
                    <Label text="Tất cả phiên đấu giá" 
                           styleClass="title-medium"/>
                    <FlowPane fx:id="auctionGrid" 
                              hgap="20" 
                              vgap="20"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>