<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.ProductManagementController"
            styleClass="root"
            prefWidth="1280"
            prefHeight="800">

    <!-- === SIDEBAR === -->
    <left>
        <StackPane fx:id="sidebarContainer"/>
    </left>

    <!-- === CONTENT AREA === -->
    <center>
        <HBox spacing="24">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <!-- === CỘT TRÁI: DANH SÁCH SẢN PHẨM === -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">

                <Label text="Sản phẩm của tôi" styleClass="title-large"/>

                <TableView fx:id="tblItems" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" 
                                     text="Tên sản phẩm" 
                                     prefWidth="220"/>
                        <TableColumn fx:id="colDescription" 
                                     text="Mô tả" 
                                     prefWidth="260"/>
                        <TableColumn fx:id="colStartingPrice" 
                                     text="Giá khởi điểm" 
                                     prefWidth="160"/>
                        <TableColumn fx:id="colType" 
                                     text="Loại" 
                                     prefWidth="140"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- === CỘT PHẢI: FORM CHI TIẾT === -->
            <VBox styleClass="card" 
                  spacing="16" 
                  prefWidth="380" 
                  minWidth="340" 
                  maxWidth="440">

                <Label text="Chỉnh sửa sản phẩm" styleClass="title-medium"/>

                <VBox spacing="6">
                    <Label text="TÊN SẢN PHẨM" styleClass="label-caption"/>
                    <TextField fx:id="txtName" promptText="Nhập tên sản phẩm"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="MÔ TẢ" styleClass="label-caption"/>
                    <TextArea fx:id="txtDescription" 
                              prefRowCount="3" 
                              wrapText="true"
                              promptText="Nhập mô tả sản phẩm"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="GIÁ KHỞI ĐIỂM (VND)" styleClass="label-caption"/>
                    <TextField fx:id="txtStartingPrice" 
                               promptText="Nhập giá khởi điểm"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="LOẠI" styleClass="label-caption"/>
                    <ComboBox fx:id="cbItemType" 
                              maxWidth="Infinity" 
                              promptText="Chọn loại"/>
                </VBox>

                <!-- === ACTION BUTTONS === -->
                <HBox spacing="12">
                    <Button text="Thêm" 
                            styleClass="btn-outline" 
                            onAction="#onAddClicked"/>
                    <Button text="Cập nhật" 
                            styleClass="btn-primary" 
                            onAction="#onUpdateClicked"/>
                </HBox>

                <HBox spacing="12">
                    <Button text="Làm mới" 
                            styleClass="btn-text" 
                            onAction="#onClearClicked"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Xoá" 
                            styleClass="btn-danger" 
                            onAction="#onDeleteClicked"/>
                </HBox>
            </VBox>
        </HBox>
    </center>

</BorderPane>