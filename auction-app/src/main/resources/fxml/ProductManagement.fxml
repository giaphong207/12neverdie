<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.ProductManagementController"
            prefWidth="900"
            prefHeight="600">

<top>
    <Label text="Quản lý sản phẩm"
           style="-fx-font-size: 24px; -fx-font-weight: bold;">
        <BorderPane.margin>
            <Insets top="20" right="20" bottom="10" left="20"/>
        </BorderPane.margin>
    </Label>
</top>

<center>
    <TableView fx:id="tblItems">
        <columns>
            <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="180"/>
            <TableColumn fx:id="colDescription" text="Mô tả" prefWidth="300"/>
            <TableColumn fx:id="colStartingPrice" text="Giá khởi điểm" prefWidth="150"/>
            <TableColumn fx:id="colType" text="Loại" prefWidth="120"/>
        </columns>
    </TableView>
</center>

<right>
    <VBox spacing="12" prefWidth="300">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <Label text="Thông tin sản phẩm"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <TextField fx:id="txtName" promptText="Tên sản phẩm"/>

        <TextArea fx:id="txtDescription"
                  promptText="Mô tả"
                  prefRowCount="4"
                  wrapText="true"/>

        <TextField fx:id="txtStartingPrice" promptText="Giá khởi điểm"/>

        <ComboBox fx:id="cbItemType" promptText="Loại sản phẩm" maxWidth="Infinity"/>

        <HBox spacing="8">
            <Button text="Add" onAction="#onAddClicked"/>
            <Button text="Update" onAction="#onUpdateClicked"/>
            <Button text="Delete" onAction="#onDeleteClicked"/>
            <Button text="Clear" onAction="#onClearClicked"/>
        </HBox>
    </VBox>
</right>

</BorderPane>