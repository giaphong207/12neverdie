<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.ProductManagementController"
            styleClass="root"
            prefWidth="1280"
            prefHeight="800">

    <left>
        <StackPane fx:id="sidebarContainer"/>
    </left>

    <center>
        <HBox spacing="24">
            <padding>
                <Insets top="48" right="48" bottom="48" left="48"/>
            </padding>

            <!-- Cột trái: Danh sách sản phẩm -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">

                <VBox spacing="10">
                    <Label text="Sản phẩm của tôi" styleClass="title-serif"/>
                    <Region styleClass="champagne-divider"/>
                </VBox>

                <TableView fx:id="tblItems" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="220"/>
                        <TableColumn fx:id="colDescription" text="Mô tả" prefWidth="260"/>
                        <TableColumn fx:id="colStartingPrice" text="Giá khởi điểm" prefWidth="160"/>
                        <TableColumn fx:id="colType" text="Loại" prefWidth="140"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Cột phải: Form chi tiết -->
            <VBox styleClass="card" spacing="16" prefWidth="380" minWidth="340" maxWidth="440">

                <Label text="Chỉnh sửa sản phẩm" styleClass="title-serif-small"/>
                <Region styleClass="champagne-divider"/>

                <VBox spacing="6">
                    <Label text="TÊN SẢN PHẨM" styleClass="label-tiny-uppercase"/>
                    <TextField fx:id="txtName"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="MÔ TẢ" styleClass="label-tiny-uppercase"/>
                    <TextArea fx:id="txtDescription" prefRowCount="3" wrapText="true"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="GIÁ KHỞI ĐIỂM (VND)" styleClass="label-tiny-uppercase"/>
                    <TextField fx:id="txtStartingPrice"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="LOẠI" styleClass="label-tiny-uppercase"/>
                    <ComboBox fx:id="cbItemType" maxWidth="Infinity" promptText="Chọn loại"/>
                </VBox>

                <Region prefHeight="8"/>

                <HBox spacing="12">
                    <Button text="THÊM" styleClass="btn-outline" onAction="#onAddClicked"/>
                    <Button text="CẬP NHẬT" styleClass="btn-primary" onAction="#onUpdateClicked"/>
                </HBox>

                <HBox spacing="12">
                    <Button text="LÀM MỚI" styleClass="btn-text" onAction="#onClearClicked"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="XÓA" styleClass="btn-text-danger" onAction="#onDeleteClicked"/>
                </HBox>
            </VBox>
        </HBox>
    </center>

</BorderPane>